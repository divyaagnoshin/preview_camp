# Dedicated DB connection — same database as the monolith, separate pool
DB_HOST=localhost
DB_PORT=5432
DB_NAME=preview_campaign
DB_USER=postgres
DB_PASSWORD=Admin@123

# Pool sizing tuned for hot transactional workload (agent allocation)
QUEUE_DB_POOL_MAX=50
QUEUE_DB_STATEMENT_TIMEOUT_MS=5000
QUEUE_DB_IDLE_TIMEOUT_MS=30000
QUEUE_DB_CONNECTION_TIMEOUT_MS=2000

# Service port — distinct from main backend (3001)
PORT=3002

# Must match the JWT_SECRET of the main backend so tokens are accepted
JWT_SECRET=45a89b3f8e736bb2b98424c1ab5bcc01d14fb9c51c71d857d6c36dbe3cd6dd9e

# CORS — frontend dev server
CLIENT_URL=http://localhost:5173

# Heartbeat / recovery loop
HEARTBEAT_STALE_SECONDS=60
HEARTBEAT_CHECK_INTERVAL_SECONDS=30
