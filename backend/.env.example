# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=preview_campaign
DB_USER=postgres
DB_PASSWORD=Admin@123

# Server
PORT=3001
NODE_ENV=development

# Auth
JWT_SECRET=45a89b3f8e736bb2b98424c1ab5bcc01d14fb9c51c71d857d6c36dbe3cd6dd9e
JWT_EXPIRES_IN=8h

# Heartbeat
HEARTBEAT_STALE_SECONDS=60
HEARTBEAT_CHECK_INTERVAL_SECONDS=30

# How many hours between CCS cleanup runs for infinite campaigns.
CLEANUP_INTERVAL_HOURS=24


# ── FreeSWITCH (Option A — browser WebRTC via WSS) ──────────
# The browser registers as a SIP user over WebSocket-Secure and dials
# through this server. The backend also opens an ESL connection to
# correlate channel events back to contact_interactions.
FS_HOST=192.168.9.221
FS_SIP_DOMAIN=192.168.9.221
FS_WSS_URL=wss://192.168.9.221:7443
FS_STUN_URL=stun:stun.l.google.com:19302

# ESL — used by the backend to subscribe to channel events
FS_ESL_HOST=192.168.9.221
FS_ESL_PORT=8021
FS_ESL_PASSWORD=ClueCon
FS_ESL_ENABLED=true

# Outbound caller ID surfaced on the PSTN leg
FS_OUTBOUND_CALLER_ID_NUMBER=+10000000000
FS_OUTBOUND_CALLER_ID_NAME=Preview Campaign

# Digits prepended to plain national numbers before they are sent to
# FreeSWITCH, so the dialplan's outbound route can match. Common values:
#   "0"    \u2014 India PSTN trunks that expect 0 + 10-digit mobile
#   "9"    \u2014 PBX setups where 9 grabs an outside line
#   ""     \u2014 dialplan accepts the bare number as-is
# Numbers already in E.164 form (starting with +) bypass this prefix.
FS_DIAL_PREFIX=
